{
  "name": "test-run-ui",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --code-coverage",
    "test-headless": "ng test --browsers=ChromeHeadless --watch=false",
    "test-ci": "ng test --no-watch --no-progress --code-coverage --browsers=ChromeHeadless",
    "docker": "docker rm -f test-run-ui && docker rmi test-run-ui && docker build -t test-run-ui . &&  docker run -d -p 80:80 --name test-run-ui test-run-ui",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "format": "npx prettier --check .",
    "format:fix": "npx prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/material": "^20.2.14",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/component-store": "21.0.1",
    "@ngrx/effects": "21.0.1",
    "@ngrx/operators": "^21.0.1",
    "@ngrx/signals": "^21.0.1",
    "@ngrx/store": "21.0.1",
    "ngx-mask": "^16.4.2",
    "ngx-mqtt": "^17.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.2",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "19.0.0-alpha.4",
    "@angular-eslint/eslint-plugin": "19.0.0-alpha.4",
    "@angular-eslint/eslint-plugin-template": "19.0.0-alpha.4",
    "@angular-eslint/schematics": "19.0.0-alpha.4",
    "@angular-eslint/template-parser": "19.0.0-alpha.4",
    "@angular/build": "^21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@types/jasmine": "~4.3.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "baseline-browser-mapping": "^2.9.14",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.4.0",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.5.3",
    "prettier-eslint": "^13.0.0",
    "typescript": "~5.9.3"
  }
}
