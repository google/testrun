<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Testrun Report</title>
  <style>{{ styles }}</style>
</head>
<body>
  <div class="page">
    <div class="header">
    <div class="header-info">
      {# Badge #}
      <p class="header-info-badge">
        <img src="data:image/png;base64, {{ icon }}" alt="">
        <span>{{ name }}</span>
      </p>
      <span style="font-weight:600">{{ title }}</span>
    </div>
    <img src="data:image/png;base64, {{ logo }}" alt="Testrun" width="90" style="position: absolute;top: 40%; right: 0px;"></img>
  </div>
<div class="module-page-content">
  {% if module_header %}
    <h4 class="page-heading">{{ module_header }}</h4>
    {% if summary_headers %}
      <table class="module-summary">
    {% endif %}
  {% elif summary_headers %}
    <table class="module-summary not-first">
  {% endif %}
    {% if summary_headers %}
      <thead>
        <tr>
          {% for header in summary_headers %}
            <th>{{ header }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        <tr>
          {% for cell in summary_data %}
            <td>{{ cell }}</td>
          {% endfor %}
        </tr>
      </tbody>
      </table>
    {% endif %}
  {% block content %}{% endblock content %}
</div>
<div class="footer">
    <div class="footer-label">Testrun {{ version }}</div>
    <div class="footer-label page-index" style="right: 0px"></div>
  </div>
  </div>
  <div style="break-after:page"></div>
</body>
</html>